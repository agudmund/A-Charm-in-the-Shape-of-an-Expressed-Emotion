      "caption": "Heart light trails over cityscape",
      "source_path": "C:\\Users\\thisg\\Desktop\\A Charm in the shape of an Expressed Emotion\\Images\\downloadedImage (6).png",
      "show_border": false,
      "depth_front": false
    },
    {
      "node_id": 0,
