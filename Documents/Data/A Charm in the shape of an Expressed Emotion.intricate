    {
      "node_id": 0,
      "node_type": "about",
      "title": "OS titlebars that curl up into themselves without that being a Windows feature",
      "uuid": "268a4cf5f6bd479ca5cc7d1615db7c67",
      "x": -1243.7232799025833,
      "y": -116.44026387335907,
      "width": 809.1639650078382,
      "height": 33.596339647876455,
      "z_value": 0.0,
      "ports_visible": false,
