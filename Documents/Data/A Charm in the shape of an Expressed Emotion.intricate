    {
      "node_id": 0,
      "node_type": "image",
      "title": "Image",
      "uuid": "895d6705b9b54b119cc56513f6564939",
      "x": -424.57614248575317,
      "y": -637.0279489590089,
      "width": 252.0831630720641,
      "height": 528.0827624221357,
      "z_value": 0.0,
      "ports_visible": false,
      "shelf_visible": false,
      "image_b64": "",
      "cache_key": "e89113ba69f7a84da392ccc34592b57a651bc1f024626f1376c2397ea445be8b",
      "caption": "Hands holding glowing lighter sparks",
      "source_path": "C:\\Users\\thisg\\Desktop\\A Charm in the shape of an Expressed Emotion\\Images\\downloadedImage (2).png",
      "source_size": 213430,
      "source_mtime": 1771066275.287526,
      "show_border": true,
      "depth_front": false
    },
    {
      "node_id": 0,
      "node_type": "claude_response",
      "title": "Response",
      "uuid": "3df3a6200355419a8958f37cce45bee2",
      "x": -999999.0,
      "y": -999999.0,
      "width": 420.0,
      "height": 372.0,
      "z_value": 0.0,
      "ports_visible": false,
      "shelf_visible": true,
      "label": "The root cause: `QGraphicsItem.data(key)` is a Qt method that exists on every graphics item, so `hasattr(item, 'data')` was `True` for ports, wires, everything \u2014 and `QGraphicsEllipseItem` (which ports extend) also has `rect()`. Every probe hit a port and blocked. `isinstance(item, BaseNode)` only matches actual canvas nodes.",
      "depth_front": false,
      "node_tint": ""
    },
