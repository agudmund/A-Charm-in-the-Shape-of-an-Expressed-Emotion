    {
      "node_id": 0,
      "node_type": "warm",
      "title": "Accurate",
      "uuid": "2fde0556ec284785aaa1a7d05500eeb4",
      "x": 14330.369354351145,
      "y": 3793.236233957921,
      "width": 300.0,
